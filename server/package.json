{
  "name": "pitchside-server",
  "version": "1.0.0",
  "private": true,
  "engines": { "node": ">22" },
  "scripts": {
    "start": "node src/server.js",
    "server": "nodemon src/server.js",
    "client": "npm start --prefix ../client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node src/utils/seed.js"
  },
  "dependencies": {
    "axios": "0.27.2",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.0.3",
    "express": "4.18.1",
    "express-rate-limit": "6.7.0",
    "express-validator": "6.14.2",
    "helmet": "6.0.1",
    "jsonwebtoken": "8.5.1",
    "mongoose": "6.5.5",
    "morgan": "1.10.0",
    "node-cache": "5.1.2"
  },
  "devDependencies": {
    "concurrently": "7.6.0",
    "nodemon": "2.0.20"
  }
}
